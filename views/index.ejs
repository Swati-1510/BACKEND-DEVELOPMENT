<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">

<nav class="nav-reveal">
  <div class="nav-logo">SKIN.AI</div>
  <button class="nav-btn">Shop Now</button>
</nav>

<section class="hero">
  <h1 class="reveal-text">Elevate Your<br>Skincare Routine</h1>
  <p class="reveal-text">Scroll down to explore our premium collection in a seamless, interactive 3D space.</p>

  <div class="scroll-indicator reveal-text">
    <div class="scroll-dot"></div>
  </div>
</section>

<section class="carousel-wrapper" id="carousel-section">
  <div class="carousel-track" id="carousel-track">

    <div class="product-card clay-element">
      <div class="img-container">
        <img src="https://cdn.shopify.com/s/files/1/0185/5999/1872/files/cc-dp.jpg?v=1764280792" alt="Product 1">
      </div>
    </div>

    <div class="product-card clay-element">
      <div class="img-container">
        <img src="https://cdn.shopify.com/s/files/1/0185/5999/1872/files/cc-serum.jpg?v=1764279474" alt="Product 2">
      </div>
    </div>

    <div class="product-card clay-element">
      <div class="img-container">
        <img src="https://cdn.shopify.com/s/files/1/0185/5999/1872/files/dermd-products.png?v=1753033534" alt="Product 3" style="object-fit: contain;">
      </div>
    </div>

    <div class="product-card clay-element">
      <div class="img-container">
        <img src="https://cdn.shopify.com/s/files/1/0185/5999/1872/files/exf-square-02.jpg?v=1750856965" alt="Product 4">
      </div>
    </div>

    <div class="product-card clay-element">
      <div class="img-container">
        <img src="https://cdn.shopify.com/s/files/1/0185/5999/1872/files/fes-square-01.webp?v=1733996576" alt="Product 5">
      </div>
    </div>

    <div class="product-card clay-element">
      <div class="img-container">
        <img src="https://cdn.shopify.com/s/files/1/0185/5999/1872/files/lit-square-03.webp?v=1733734767" alt="Product 6">
      </div>
    </div>

  </div>
</section>

<section class="footer">
  <div class="footer-card clay-element scroll-reveal">
    <h2>Ready to transform your skin?</h2>
    <button class="nav-btn" style="padding: 20px 40px; font-size: 1.2rem;">Get Started</button>
  </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</body>
</html>